{"version":3,"kind":"Article","sha256":"29f35396310523423f57440ba06ba7220ec1a0560812225a17df2c280e4a2619","slug":"rdm","location":"/rdm.md","dependencies":[],"frontmatter":{"title":"Open Science","content_includes_title":false,"github":"https://github.com/DunklesArchipel/akeprojects","numbering":{"figure":{"enabled":true}},"source_url":"https://github.com/DunklesArchipel/akeprojects/blob/main/docs/rdm.md","edit_url":"https://github.com/DunklesArchipel/akeprojects/edit/main/docs/rdm.md","exports":[{"format":"md","filename":"rdm.md","url":"/build/rdm-1b8127562b3d8ac3e9a8b0f2f88cc2c2.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"While open science (including research data management, RDM, workflows) has been propagated for several decades, it has only become a central part of ongoing research initiatives in recent years.\nI am convinced that well-implemented RDM workflows improve the organization, evaluation, and dissemination of scientific results.\nAutomation removes the burden of repetitive tasks and creates more room for scientific thinking.\nFunding agencies are very aware of the advantages of such implementations; therefore, providing clear information on data handling has become a key criterion for the acceptance of research proposals.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"WInteBv6OX"}],"key":"rqtLb8Hujl"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"In my opinion, some key challenges are:","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"BIulZZV2e4"}],"key":"o6U7UthPfi"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":10,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":10,"